import java.util.*;

class Solution {
    public int[] pathExistenceQueries(int n, int[] nums, int maxDiff, int[][] queries) {
        // Step 1: Pair values with their original index and sort by value
        int[][] sortedPairs = new int[n][2];
        for (int i = 0; i < n; i++) {
            sortedPairs[i][0] = nums[i]; // value
            sortedPairs[i][1] = i;       // original index
        }
        
        // Sort based on the values in ascending order
        Arrays.sort(sortedPairs, (a, b) -> Integer.compare(a[0], b[0]));
        
        // Map original index -> sorted index position
        int[] origToSorted = new int[n];
        for (int i = 0; i < n; i++) {
            origToSorted[sortedPairs[i][1]] = i;
        }
        
        // Step 2: Initialize binary lifting table
        int LOG = 18;
        int[][] st = new int[n][LOG];
        
        // Use a two-pointer approach to find the maximum 1-hop reach for each sorted element
        int r = 0;
        for (int i = 0; i < n; i++) {
            while (r + 1 < n && sortedPairs[r + 1][0] - sortedPairs[i][0] <= maxDiff) {
                r++;
            }
            st[i][0] = r; // 2^0 = 1 hop max reach
        }
        
        // Step 3: Populate binary lifting table
        for (int j = 1; j < LOG; j++) {
            for (int i = 0; i < n; i++) {
                st[i][j] = st[st[i][j - 1]][j - 1];
            }
        }
        
        // Step 4: Process queries
        int[] ans = new int[queries.length];
        for (int i = 0; i < queries.length; i++) {
            int u = queries[i][0];
            int v = queries[i][1];
            
            if (u == v) {
                ans[i] = 0;
                continue;
            }
            
            // Convert to sorted positions and guarantee a <= b
            int a = origToSorted[u];
            int b = origToSorted[v];
            if (a > b) {
                int temp = a;
                a = b;
                b = temp;
            }
            
            int steps = 0;
            int curr = a;
            
            // Greedily lift 'curr' as far as possible without reaching or passing 'b'
            for (int j = LOG - 1; j >= 0; j--) {
                if (st[curr][j] < b) {
                    curr = st[curr][j];
                    steps += (1 << j);
                }
            }
            
            // Check if 1 final hop can cover or pass target index b
            if (st[curr][0] >= b) {
                ans[i] = steps + 1;
            } else {
                ans[i] = -1;
            }
        }
        
        return ans;
    }
}
