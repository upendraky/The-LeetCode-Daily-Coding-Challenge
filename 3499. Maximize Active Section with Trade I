class Solution {
    public int maxActiveSectionsAfterTrade(String s) {
        int n = s.length();

        // Count original active sections
        int ones = 0;
        for (char c : s.toCharArray()) {
            if (c == '1') {
                ones++;
            }
        }

        // Augment the string
        String t = "1" + s + "1";

        int maxGain = 0;
        int i = 0;

        while (i < t.length()) {

            // Find a block of zeros
            if (t.charAt(i) == '0') {

                int leftZeros = 0;

                while (i < t.length() && t.charAt(i) == '0') {
                    leftZeros++;
                    i++;
                }

                // Find the middle block of ones
                if (i >= t.length()) {
                    break;
                }

                while (i < t.length() && t.charAt(i) == '1') {
                    i++;
                }

                // We need another zero block after the 1 block
                int rightZeros = 0;

                int j = i;

                while (j < t.length() && t.charAt(j) == '0') {
                    rightZeros++;
                    j++;
                }

                if (rightZeros > 0) {
                    maxGain = Math.max(
                        maxGain,
                        leftZeros + rightZeros
                    );
                }

            } else {
                i++;
            }
        }

        return ones + maxGain;
    }
}
