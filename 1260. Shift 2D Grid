import java.util.*;

class Solution {
    public List<List<Integer>> shiftGrid(int[][] grid, int k) {
        int m = grid.length;
        int n = grid[0].length;
        int total = m * n;

        // Avoid unnecessary full rotations
        k = k % total;

        List<List<Integer>> result = new ArrayList<>();

        for (int i = 0; i < m; i++) {
            List<Integer> row = new ArrayList<>();

            for (int j = 0; j < n; j++) {

                // Current position in the shifted grid
                int newIndex = i * n + j;

                // Find where this value came from
                int oldIndex = (newIndex - k + total) % total;

                int oldRow = oldIndex / n;
                int oldCol = oldIndex % n;

                row.add(grid[oldRow][oldCol]);
            }

            result.add(row);
        }

        return result;
    }
}
